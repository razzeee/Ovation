{
  "name": "ovation",
  "version": "1.0.0",
  "type": "module",
  "description": "Ovation - App Review & Ratings Service",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:admin": "vite dev",
    "build:admin": "vite build",
    "build": "bun run build:admin",
    "start": "bun run src/index.ts",
    "lint": "biome check src/ admin-ui/ tests/",
    "lint:fix": "biome check --fix src/ admin-ui/ tests/",
    "format": "biome format --write src/ admin-ui/ tests/",
    "format:check": "biome format src/ admin-ui/ tests/",
    "typecheck": "tsc --noEmit",
    "typecheck:admin": "tsc --noEmit -p tsconfig.admin.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "cli:ratings": "bun run src/cli/ratings.ts",
    "cli:fsck": "bun run src/cli/fsck.ts",
    "cli:taboo-check": "bun run src/cli/taboo-check.ts",
    "cli:taboo-import": "bun run src/cli/taboo-import.ts",
    "cli:appstream-import": "bun run src/cli/appstream-import.ts"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@sentry/bun": "^9.27.0",
    "@sentry/react": "^9.27.0",
    "@tanstack/react-query": "^5.80.6",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^5.6.0",
    "drizzle-orm": "^0.44.2",
    "fast-xml-parser": "^5.2.3",
    "hono": "^4.7.11",
    "hono-openapi": "^1.3.0",
    "jose": "^6.0.11",
    "postgres": "^3.4.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "recharts": "^2.15.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.2.14",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.3"
  }
}
